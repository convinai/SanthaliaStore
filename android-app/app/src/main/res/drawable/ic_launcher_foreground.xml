<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground for the adaptive icon: a saffron rounded "name plate"
    (echoing the actual shop sign) with a bold white "S" inside.
    All artwork stays inside the 66dp safe zone so circular launchers
    don't crop it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Saffron rounded rectangle — the brand "name plate" -->
    <path
        android:fillColor="#EA580C"
        android:pathData="M30,34 L78,34 A8,8 0 0 1 86,42 L86,74 A8,8 0 0 1 78,82 L30,82 A8,8 0 0 1 22,74 L22,42 A8,8 0 0 1 30,34 Z" />

    <!-- Bold stroked white "S" centered in the plate -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="
            M66,49
            C66,46 62,44 56,44
            L52,44
            C46,44 42,46 42,50
            C42,54 46,56 54,57
            C62,58 66,60 66,64
            C66,68 62,70 56,70
            L52,70
            C46,70 42,68 42,64" />
</vector>
