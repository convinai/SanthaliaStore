<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash window background. Light amber surface with the full launcher
    icon (saffron square + white S) centred. The launcher foreground alone
    is pure white and would be invisible on this amber surface, so we
    render the composed mipmap instead.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_background" />
    <item
        android:drawable="@mipmap/ic_launcher"
        android:gravity="center"
        android:width="120dp"
        android:height="120dp" />
</layer-list>
