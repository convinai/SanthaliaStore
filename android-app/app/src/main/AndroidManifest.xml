<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet only used for sync to Apps Script. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Camera is OPTIONAL. The Bills capture flow can fall back to the
        gallery picker on devices without a camera (tablets, some POS
        terminals). Marking the feature non-required keeps the Play
        Store / sideload-install filter open. We do NOT declare the
        CAMERA permission because the TakePicture contract launches the
        system camera app and uses a FileProvider URI — no permission
        is required on the caller's side.
    -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:name=".RateCardApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SanthaliaRateCard"
        android:hardwareAccelerated="true"
        android:largeHeap="false"
        tools:targetApi="31">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.SanthaliaRateCard.Splash"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation|screenLayout|smallestScreenSize|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            We initialise WorkManager manually inside RateCardApp via the
            Configuration.Provider interface, so we disable the default
            content-provider-based init here. This keeps cold start fast.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
            FileProvider for the camera capture flow.

            ActivityResultContracts.TakePicture() needs a writable content
            URI to hand the system camera app. We grant it on a per-Uri
            basis via FileProvider so we never have to hold the legacy
            WRITE_EXTERNAL_STORAGE permission.

            The exposed directory (`bills/` under filesDir) is the same
            place BillImageCache stores compressed images, so the camera
            output drops directly into the cache and the compressor can
            run against it in place.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
